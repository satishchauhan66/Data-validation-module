# Copy into your shell or a local .env (not committed). quickstart.py reads these.

DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USERNAME=
DB2_PASSWORD=
AZURE_SQL_HOST=
AZURE_SQL_DATABASE=
AZURE_SQL_USERNAME=

# Optional: quickstart output folders (defaults INFOQFIT / SS-DEV-DB21D)
# DV_OUTPUT_ORG=
# DV_OUTPUT_INSTANCE=

# Row-count tuning for very large DB2 tables (900 GB - 4 TB).
# DV_ROW_COUNT_MODE: exact | estimate | auto | skip       (default: auto)
# DV_LARGE_TABLE_THRESHOLD_GB: in 'auto' mode, tables larger than this use estimates  (default: 50)
# DV_ESTIMATE_TOLERANCE_PCT: estimate-vs-estimate match tolerance                    (default: 1.0)
# DV_EXCLUDE_TABLES: comma-separated table names to skip entirely
# DV_ESTIMATE_TABLES: comma-separated table names that always use estimate path
# DV_ROW_COUNT_MODE=auto
# DV_LARGE_TABLE_THRESHOLD_GB=50
# DV_ESTIMATE_TOLERANCE_PCT=1.0
# DV_EXCLUDE_TABLES=BIG_ARCHIVE_TBL,STAGING_TMP
# DV_ESTIMATE_TABLES=HUGE_FACT_TABLE

# Exact-count survival knobs (use when you want EXACT COUNT(*) on multi-TB tables).
# DV_DIRTY_READ_COUNT: append WITH UR (DB2) / WITH (NOLOCK) (Azure SQL)         (default: true)
# DV_ROW_COUNT_TIMEOUT_SEC: per-table query timeout, 0 = unlimited              (default: 0)
# DV_CONNECT_TIMEOUT_SEC: connect-time timeout for both DB2 + Azure SQL          (default: 30)
# DV_DIRTY_READ_COUNT=true
# DV_ROW_COUNT_TIMEOUT_SEC=3600
# DV_CONNECT_TIMEOUT_SEC=30
