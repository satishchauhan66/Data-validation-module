# Copy to `.env` in the repo root (or export these in your shell).
# `examples/quickstart.py` loads `.env` from repo root or `examples/` if `python-dotenv` is installed:
#   pip install python-dotenv
#
# --- Source (DB2) ---
DV_SOURCE_TYPE=db2
DV_SOURCE_HOST=your-db2-host
DV_SOURCE_PORT=50000
DV_SOURCE_DATABASE=YOUR_DB
DV_SOURCE_USERNAME=your_user
DV_SOURCE_PASSWORD=your_secret

# --- Target (Azure SQL) ---
DV_TARGET_TYPE=azure_sql
DV_TARGET_HOST=your-server.database.windows.net
DV_TARGET_DATABASE=your_database
DV_TARGET_USERNAME=your_login_or_aad_user
# Leave empty to use interactive / MSAL browser sign-in (same as omitting password in code)
DV_TARGET_PASSWORD=

# Optional: password auth for Azure
# DV_TARGET_AUTH=password
# For some MI / dev servers:
# DV_TARGET_TRUST_SERVER_CERT=true

# Optional JDBC / ODBC login timeout (seconds), both sides
# DV_CONNECT_TIMEOUT_SEC=120

# Data validation: max seconds per SQL statement for DISTINCT/CHECKSUM/FK/null checks (not row counts).
# Prevents runs from hanging forever on one huge table or lock. Default in quickstart is 600; set to 0 for no limit.
# DV_DATA_QUERY_TIMEOUT_SEC=600

# Which data validations to run (comma-separated). Default is row_counts only (fast). Use "all" for full suite.
# Phases: row_counts, column_nulls, distinct_keys, checksum, referential_integrity, constraint_integrity
# DV_DATA_VALIDATIONS=row_counts
# DV_DATA_VALIDATIONS=all

# --- Schemas for USERID -> dbo style reports ---
DV_SOURCE_SCHEMA=USERID
DV_TARGET_SCHEMA=dbo

# --- Output paths (optional) ---
# DV_OUTPUT_ORG=INFOQFIT
# DV_OUTPUT_INSTANCE=SS-DEV-DB21D

# --- DB2 troubleshooting ---
# "Connection refused" / ERRORCODE=-4499 / SQLSTATE=08001: TCP reached the host (or resolved IP)
# but nothing accepted the port. Common causes:
#   - Not on corporate VPN (hosts like SS-*-DB22D often resolve to 10.x private addresses).
#   - DB2 instance down, wrong DV_SOURCE_PORT (default is often 50000), or firewall blocks your PC.
#   - Try: ping / Test-NetConnection <host> -Port 50000 from PowerShell while on VPN.
